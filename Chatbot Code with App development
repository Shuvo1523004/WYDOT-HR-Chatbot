/* ─── SIGMOID FUNCTION ─── */
function sigmoid(x) { return 1 / (1 + Math.exp(-x)); }

/* ─── GET SURVEY RESPONSES ─── */
function getSurveyData() {
  const data = {};
  document.querySelectorAll('.scale-row').forEach(row => {
    const field = row.getAttribute('data-field');
    const selected = row.querySelector('.scale-btn.selected');
    data[field] = selected ? parseInt(selected.getAttribute('data-val')) : null;
  });
  return data;
}

/* ═══════════════════════════════════════════════════════
   SCALE: 1=Best, 4=Worst (ALL items, unified)
   contribution = weight * (val - 1)
   val=1 → 0 risk; val=4 → 3*weight (max risk)
═══════════════════════════════════════════════════════ */

/* ─── COMPUTE RISK ─── */
function computeRisk(data) {
  const contributions = [];
  // TRANSLATION LAYER: UI presents 1=Poor/Strongly Disagree → 4=Excellent/Strongly Agree
  // Risk formula: val=1 (Poor) → contribution=3*weight (max risk)
  //               val=4 (Excellent) → contribution=0 (no risk)
  Object.entries(LR_WEIGHTS).forEach(([field, weight]) => {
    const val = data[field];
    if (val !== null && val !== undefined) {
      const contribution = weight * (4 - val);
      const riskLabel = val === 1 ? 'Strongly Disagree / Poor'
                      : val === 2 ? 'Disagree / Fair'
                      : val === 3 ? 'Agree / Good'
                      : 'Strongly Agree / Excellent';
      contributions.push({ field, val, weight, contribution, riskLabel });
    }
  });

  const n = contributions.length;
  if (n === 0) return { risk: 0.5, contributions };

  const totalContrib = contributions.reduce((s, c) => s + c.contribution, 0);
  const maxPossible = Object.values(LR_WEIGHTS).reduce((s,w) => s + w * 3, 0);
  const maxItems = Object.keys(LR_WEIGHTS).length;
  // Scale up for partial responses
  const scaledTotal = totalContrib * (maxItems / n);
  const logit = LR_INTERCEPT + (scaledTotal / maxPossible) * 8.0;
  const risk = Math.max(0.04, Math.min(0.97, sigmoid(logit)));
  return { risk, contributions };
}

/* ─── COMPUTE THEME SCORES (1–4 scale, higher = more risk) ─── */
function computeThemeScores(data) {
  // Returns avg score per theme on 1=Poor,4=Excellent UI scale
  // Lower avg = more problems = higher risk (highlighted red/amber)
  var scores = {};
  Object.keys(THEMES).forEach(function(theme) {
    var fields = THEMES[theme].fields;
    var vals = fields.map(function(f){ return data[f]; })
                     .filter(function(v){ return v !== null && v !== undefined && !isNaN(v); });
    scores[theme] = vals.length > 0 ? vals.reduce(function(a,b){ return a+b; }, 0) / vals.length : 2.5;
  });
  return scores;
}

/* ─── RISK CATEGORY ─── */
function getRiskCat(risk) {
  if (risk >= 0.65) return { cat: 'HIGH',   cls: 'high',   color: '#d63030' };
  if (risk >= 0.35) return { cat: 'MEDIUM', cls: 'medium', color: '#c97b00' };
  return                   { cat: 'LOW',    cls: 'low',    color: '#1a7a4a' };
}

/* ─── RENDER THEME BARS (1=best, 4=worst — sort descending = worst first) ─── */
function renderThemeBars(containerId, themeScores) {
  // Score 1=Poor(red/risk) → 4=Excellent(green/strength)
  // Sort: worst (lowest score) first so HR sees problems at top
  var container = document.getElementById(containerId);
  if (!container) return;
  var sorted = Object.entries(themeScores).sort(function(a,b){ return a[1]-b[1]; });
  container.innerHTML = sorted.map(function(entry) {
    var theme = entry[0], score = entry[1];
    var cfg = THEMES[theme] || {icon:'', color:'#888'};
    var pct = ((score - 1) / 3 * 100).toFixed(1);
    // Color based on score: 1-2=red, 2-2.5=amber, 2.5-3=teal, 3-4=green
    var barColor, badge, badgeStyle;
    if (score < 2.0) {
      barColor = '#d63030';
      badge = 'RISK AREA';
      badgeStyle = 'background:#fdf0f0;color:#d63030;border:1px solid #f8c8c8;';
    } else if (score < 2.5) {
      barColor = '#c97b00';
      badge = 'CONCERN';
      badgeStyle = 'background:#fff8ed;color:#c97b00;border:1px solid #fde5b0;';
    } else if (score < 3.0) {
      barColor = '#0891b2';
      badge = 'MODERATE';
      badgeStyle = 'background:#f0fafb;color:#0891b2;border:1px solid #b8e8f4;';
    } else {
      barColor = '#1a7a4a';
      badge = 'STRENGTH';
      badgeStyle = 'background:#f0faf5;color:#1a7a4a;border:1px solid #b8e8d4;';
    }
    return '<div class="theme-bar-row" style="margin-bottom:14px;">' +
      '<div class="theme-bar-label" style="width:180px;">' + cfg.icon + ' ' + theme + '</div>' +
      '<div class="theme-bar-track" style="flex:1;">' +
        '<div class="theme-bar-fill" style="width:' + pct + '%;background:' + barColor + ';transition:width 0.8s ease;"></div>' +
      '</div>' +
      '<div style="width:52px;text-align:right;font-weight:700;font-size:12px;color:' + barColor + ';">' + score.toFixed(2) + '</div>' +
      '<div style="margin-left:8px;"><span style="' + badgeStyle + 'font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;letter-spacing:0.5px;">' + badge + '</span></div>' +
      '</div>';
  }).join('');
}

