<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WYDOT · Turnover Prediction & Retention Decision Support</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root {
  --bg: #f0ece4;
  --surface: #faf8f4;
  --white: #ffffff;
  --ink: #1c1a17;
  --ink2: #4a4742;
  --ink3: #8a8680;
  --ink4: #c4c0b8;
  --border: #e0dbd0;
  --border2: #ccc7bc;
  --wydot: #00366a;
  --wydot2: #004f9f;
  --wydot3: #0066cc;
  --gold: #f4a800;
  --gold2: #ffc940;
  --red: #d63030;
  --red-bg: #fdf0f0;
  --amber: #c97b00;
  --amber-bg: #fff8ed;
  --green: #1a7a4a;
  --green-bg: #f0faf5;
  --purple: #6b35d4;
  --purple-bg: #f4f0fd;
  --teal: #1a7d8a;
  --teal-bg: #f0fafb;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 2px 8px rgba(0,0,0,0.08), 0 0 0 1px rgba(0,0,0,0.04);
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--ink); font-family: 'DM Sans', sans-serif; font-size: 14px; line-height: 1.6; }
a { color: var(--wydot2); text-decoration: none; }

/* ── TOP NAV ── */
.nav {
  background: var(--wydot);
  padding: 0 32px;
  display: flex; align-items: center; justify-content: space-between;
  height: 56px; position: sticky; top: 0; z-index: 300;
  box-shadow: 0 2px 16px rgba(0,0,0,0.3);
}
.nav-brand { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 800; color: white; display: flex; align-items: center; gap: 10px; }
.nav-badge { background: var(--gold); color: var(--wydot); font-size: 9px; font-weight: 800; padding: 3px 8px; border-radius: 100px; letter-spacing: 1.5px; text-transform: uppercase; }
.nav-tabs { display: flex; gap: 4px; }
.nav-tab { background: transparent; border: none; color: rgba(255,255,255,0.6); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; padding: 8px 14px; border-radius: 6px; cursor: pointer; transition: all 0.15s; }
.nav-tab:hover { background: rgba(255,255,255,0.1); color: white; }
.nav-tab.active { background: rgba(255,255,255,0.15); color: white; }

/* ── LAYOUT ── */
.main { max-width: 1280px; margin: 0 auto; padding: 32px 32px 80px; }

/* ── PAGES ── */
.page { display: none; }
.page.active { display: block; }

/* ── HERO ── */
.hero-block {
  background: linear-gradient(135deg, var(--wydot) 0%, var(--wydot2) 60%, #0077cc 100%);
  border-radius: var(--radius); padding: 48px 48px 44px; margin-bottom: 32px;
  position: relative; overflow: hidden; color: white;
}
.hero-block::after {
  content: ''; position: absolute; right: -40px; top: -40px;
  width: 320px; height: 320px; border-radius: 50%;
  background: rgba(255,255,255,0.04);
}
.hero-block::before {
  content: 'WYDOT'; position: absolute; right: 24px; bottom: -20px;
  font-family: 'Syne', sans-serif; font-size: 120px; font-weight: 800;
  color: rgba(255,255,255,0.04); letter-spacing: -4px; pointer-events: none;
}
.hero-eyebrow { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold2); font-weight: 600; margin-bottom: 12px; }
.hero-title { font-family: 'Syne', sans-serif; font-size: clamp(24px,3.5vw,42px); font-weight: 800; line-height: 1.1; margin-bottom: 14px; max-width: 640px; }
.hero-sub { color: rgba(255,255,255,0.7); font-size: 15px; max-width: 560px; line-height: 1.7; margin-bottom: 28px; }
.hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
.btn-hero { padding: 12px 24px; border-radius: var(--radius-sm); font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; }
.btn-primary { background: var(--gold); color: var(--wydot); }
.btn-primary:hover { background: var(--gold2); transform: translateY(-1px); }
.btn-outline { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.3); }
.btn-outline:hover { background: rgba(255,255,255,0.18); }

/* ── CARDS ── */
.card { background: var(--white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); margin-bottom: 20px; }
.card-title { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; color: var(--ink); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.card-title .icon { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }

/* ── GRID ── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

/* ── STAT CARDS ── */
.stat { background: var(--surface); border-radius: var(--radius-sm); padding: 18px 20px; border: 1px solid var(--border); }
.stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--ink3); font-weight: 600; margin-bottom: 8px; }
.stat-value { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; color: var(--ink); line-height: 1; }
.stat-sub { font-size: 12px; color: var(--ink3); margin-top: 4px; }

/* ── RISK GAUGE ── */
.risk-gauge-wrap { display: flex; flex-direction: column; align-items: center; padding: 20px 0; }
.risk-gauge-label { font-size: 13px; color: var(--ink3); margin-top: 8px; }
.risk-pct { font-family: 'Syne', sans-serif; font-size: 36px; font-weight: 800; }

/* ── THEME BARS ── */
.theme-bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.theme-bar-label { width: 160px; font-size: 12px; color: var(--ink2); flex-shrink: 0; }
.theme-bar-track { flex: 1; height: 8px; background: var(--bg); border-radius: 100px; overflow: hidden; }
.theme-bar-fill { height: 100%; border-radius: 100px; transition: width 0.8s ease; }
.theme-bar-val { width: 38px; text-align: right; font-size: 12px; font-weight: 600; color: var(--ink2); }

/* ── BADGES / PILLS ── */
.risk-pill { display: inline-flex; align-items: center; gap: 5px; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; }
.risk-pill.high { background: var(--red-bg); color: var(--red); border: 1px solid #f8c8c8; }
.risk-pill.medium { background: var(--amber-bg); color: var(--amber); border: 1px solid #fde5b0; }
.risk-pill.low { background: var(--green-bg); color: var(--green); border: 1px solid #b8e8d4; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

/* ── STRATEGY CARDS ── */
.strategy-card {
  background: var(--white); border-radius: var(--radius); padding: 20px;
  border: 1px solid var(--border); border-left: 4px solid var(--wydot2);
  margin-bottom: 12px;
}
.strategy-card.priority-1 { border-left-color: var(--red); }
.strategy-card.priority-2 { border-left-color: var(--amber); }
.strategy-card.priority-3 { border-left-color: var(--green); }
.strategy-title { font-weight: 600; font-size: 14px; color: var(--ink); margin-bottom: 6px; }
.strategy-meta { font-size: 12px; color: var(--ink3); }
.strategy-theme { display: inline-block; background: var(--purple-bg); color: var(--purple); font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 100px; margin-right: 6px; }
.strategy-effectiveness { display: inline-block; background: var(--teal-bg); color: var(--teal); font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 100px; }

/* ── FORMS ── */
.form-group { margin-bottom: 18px; }
.form-label { font-size: 12px; font-weight: 600; color: var(--ink2); margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.8px; }
.form-input, .form-select {
  width: 100%; padding: 10px 14px; border: 1px solid var(--border2);
  border-radius: var(--radius-sm); font-family: 'DM Sans', sans-serif; font-size: 14px;
  color: var(--ink); background: var(--white); outline: none; transition: border-color 0.15s;
}
.form-input:focus, .form-select:focus { border-color: var(--wydot2); box-shadow: 0 0 0 3px rgba(0,79,159,0.12); }
.scale-row { display: flex; gap: 8px; }
.scale-btn {
  flex: 1; padding: 10px; border: 1px solid var(--border2); border-radius: var(--radius-sm);
  background: var(--white); cursor: pointer; font-size: 13px; font-weight: 500;
  color: var(--ink2); transition: all 0.12s; text-align: center;
}
.scale-btn.selected { background: var(--wydot2); color: white; border-color: var(--wydot2); }
.scale-btn:hover:not(.selected) { background: var(--surface); border-color: var(--wydot2); }
.section-divider { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700; color: var(--wydot); text-transform: uppercase; letter-spacing: 1.5px; padding: 20px 0 10px; border-bottom: 2px solid var(--wydot); margin-bottom: 20px; }

/* ── TABLES ── */
.data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.data-table th { background: var(--surface); padding: 10px 14px; font-size: 11px; font-weight: 600; color: var(--ink3); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--border); text-align: left; }
.data-table td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--ink2); }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: var(--surface); }

/* ── UPLOAD ZONE ── */
.upload-zone {
  border: 2px dashed var(--border2); border-radius: var(--radius); padding: 56px 40px;
  text-align: center; cursor: pointer; transition: all 0.2s; background: var(--surface);
  position: relative;
}
.upload-zone:hover, .upload-zone.drag-over { border-color: var(--wydot2); background: rgba(0,79,159,0.04); }
.upload-zone input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
.upload-icon { font-size: 40px; margin-bottom: 12px; }
.upload-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; color: var(--ink); margin-bottom: 8px; }
.upload-sub { color: var(--ink3); font-size: 13px; }

/* ── CHATBOT ── */
.chat-container { display: flex; flex-direction: column; height: 600px; background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; }
.chat-header { background: var(--wydot); color: white; padding: 16px 20px; display: flex; align-items: center; gap: 12px; }
.chat-avatar { width: 36px; height: 36px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 800; color: var(--wydot); }
.chat-header-info .name { font-weight: 600; font-size: 14px; }
.chat-header-info .status { font-size: 12px; color: rgba(255,255,255,0.6); }
.chat-messages { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 14px; }
.msg { display: flex; gap: 10px; max-width: 85%; }
.msg.user { align-self: flex-end; flex-direction: row-reverse; }
.msg-bubble { padding: 12px 16px; border-radius: 14px; font-size: 14px; line-height: 1.6; }
.msg.ai .msg-bubble { background: var(--surface); border: 1px solid var(--border); color: var(--ink); border-radius: 2px 14px 14px 14px; }
.msg.user .msg-bubble { background: var(--wydot2); color: white; border-radius: 14px 2px 14px 14px; }
.msg-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
.msg.ai .msg-avatar { background: var(--wydot); color: white; }
.msg.user .msg-avatar { background: var(--ink3); color: white; }
.chat-input-row { display: flex; gap: 10px; padding: 16px 20px; border-top: 1px solid var(--border); background: var(--surface); }
.chat-input { flex: 1; padding: 10px 14px; border: 1px solid var(--border2); border-radius: 24px; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; background: white; }
.chat-input:focus { border-color: var(--wydot2); }
.chat-send-btn { background: var(--wydot2); color: white; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.15s; }
.chat-send-btn:hover { background: var(--wydot); }
.chat-quick-btns { display: flex; flex-wrap: wrap; gap: 8px; padding: 0 20px 12px; }
.quick-btn { background: white; border: 1px solid var(--border2); border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 500; color: var(--ink2); cursor: pointer; transition: all 0.12s; }
.quick-btn:hover { background: var(--wydot2); color: white; border-color: var(--wydot2); }

/* ── LOADING OVERLAY ── */
.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 500; align-items: center; justify-content: center; flex-direction: column; gap: 16px; }
.overlay.show { display: flex; }
.spinner { width: 48px; height: 48px; border: 4px solid rgba(255,255,255,0.2); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
.overlay-text { color: white; font-weight: 500; font-size: 15px; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── BUTTONS ── */
.btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: var(--radius-sm); font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; }
.btn-blue { background: var(--wydot2); color: white; }
.btn-blue:hover { background: var(--wydot); }
.btn-ghost { background: transparent; color: var(--ink2); border: 1px solid var(--border2); }
.btn-ghost:hover { background: var(--surface); }
.btn-sm { padding: 6px 14px; font-size: 13px; }

/* ── FACTOR CHIPS ── */
.factor-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.factor-chip { background: var(--red-bg); color: var(--red); border: 1px solid #f4c0c0; border-radius: 6px; padding: 5px 12px; font-size: 12px; font-weight: 600; }
.factor-chip.medium { background: var(--amber-bg); color: var(--amber); border-color: #f8dba0; }
.factor-chip.low { background: var(--green-bg); color: var(--green); border-color: #b8e8d4; }

/* ── SYSTEM INFO BOX ── */
.info-box { background: rgba(0,79,159,0.06); border: 1px solid rgba(0,79,159,0.15); border-radius: var(--radius-sm); padding: 16px; font-size: 13px; color: var(--ink2); line-height: 1.7; }
.info-box strong { color: var(--wydot2); }

/* ── FEATURE CARDS ── */
.feature-card { background: var(--white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 12px; }
.feature-icon { font-size: 28px; }
.feature-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--ink); }
.feature-desc { font-size: 13px; color: var(--ink3); line-height: 1.6; }

/* ── SECTION HEADING ── */
.section-head { margin-bottom: 20px; }
.section-head h2 { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; color: var(--ink); }
.section-head p { font-size: 13px; color: var(--ink3); margin-top: 4px; }

/* ── RESULT SECTION ── */
.result-section { display: none; }
.result-section.show { display: block; }

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
  .main { padding: 20px; }
  .hero-block { padding: 32px 24px; }
}

/* ── HIGHLIGHT ── */
.highlight-num { color: var(--wydot2); font-weight: 700; }
.text-danger { color: var(--red); font-weight: 600; }
.text-success { color: var(--green); font-weight: 600; }
.text-warn { color: var(--amber); font-weight: 600; }

/* ── PROGRESS BAR ── */
.progress-steps { display: flex; gap: 0; margin-bottom: 28px; }
.progress-step { flex: 1; padding: 12px 16px; background: var(--surface); border-right: 1px solid var(--border); font-size: 12px; color: var(--ink3); font-weight: 500; }
.progress-step:first-child { border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
.progress-step:last-child { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; border-right: none; }
.progress-step.active { background: var(--wydot2); color: white; }
.progress-step.done { background: var(--green-bg); color: var(--green); }

/* ── TOOLTIP HELPER ── */
.helper-text { font-size: 11px; color: var(--ink3); margin-top: 4px; }
</style>
</head>
