    const fieldLabels = { pay:'Pay rate', career:'Career growth', sup_feedback:'Supervisor feedback', proper_training:'Training', recognition:'Recognition', valued:'Feeling valued' };
    const priorityBadge = r.cat === 'HIGH' ? '<span style="color:var(--red);font-weight:700">URGENT</span>' : r.cat === 'MEDIUM' ? '<span style="color:var(--amber);font-weight:600">MODERATE</span>' : '<span style="color:var(--green)">ROUTINE</span>';
    return `<tr>
      <td>${r.idx}</td>
      <td><strong>${r.id}</strong></td>
      <td><strong>${r.risk}%</strong></td>
      <td><span class="risk-pill ${r.cls}"><span class="dot"></span> ${r.cat}</span></td>
      <td>${THEMES[r.worstTheme]?.icon || ''} ${r.worstTheme}</td>
      <td>${fieldLabels[worstField?.[0]] || (worstField?.[0] || 'N/A')}</td>
      <td>${priorityBadge}</td>
    </tr>`;
  }).join('');

  // Aggregate theme scores
  const avgThemeScores = {};
  Object.keys(THEMES).forEach(theme => {
    avgThemeScores[theme] = results.reduce((sum,r)=>sum+(r.themeScores[theme]||2.5),0)/results.length;
  });
  renderThemeBars('batch-theme-bars', avgThemeScores);

  // Risk distribution bar chart
  if (window.batchChart) window.batchChart.destroy();
  const ctx = document.getElementById('risk-dist-chart').getContext('2d');
  window.batchChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Low (<35%)', 'Medium (35–65%)', 'High (>65%)'],
      datasets: [{
        label: 'Employees',
        data: [low, med, high],
        backgroundColor: ['#1a7a4a', '#c97b00', '#d63030'],
        borderRadius: 6,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
  });

  // Org strategies — frequency analysis
  const themeCounts = {};
  results.filter(r=>r.cat!=='LOW').forEach(r => {
    themeCounts[r.worstTheme] = (themeCounts[r.worstTheme]||0)+1;
  });
  const topThemes = Object.entries(themeCounts).sort((a,b)=>b[1]-a[1]).slice(0,3).map(e=>e[0]);
  const orgStrategies = topThemes.flatMap(theme => (STRATEGIES[theme]||[]).slice(0,2).map(s=>({...s,theme})));

  var orgHtml = '';
  orgStrategies.slice(0,6).forEach(function(s, i) {
    var effColor = s.effectiveness >= 2.5 ? '#1a7a4a' : '#c97b00';
    var borderColor = s.priority === 1 ? '#d63030' : s.priority === 2 ? '#c97b00' : '#1a7a4a';
    orgHtml += '<div style="border-left:4px solid ' + borderColor + ';padding:14px 16px;margin-bottom:12px;background:var(--white);border-radius:6px;border:1px solid var(--border);border-left:4px solid ' + borderColor + ';">' +
      '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">' +
        '<span style="font-size:12px;font-weight:700;color:var(--ink);background:var(--surface);border-radius:50%;width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;">' + (i+1) + '</span>' +
        '<span style="background:var(--surface);border:1px solid var(--border);border-radius:100px;font-size:10px;font-weight:700;padding:3px 10px;color:var(--wydot2);">' + (THEMES[s.theme] ? THEMES[s.theme].icon : '') + ' ' + s.theme + '</span>' +
        '<span style="font-size:10px;font-weight:700;color:' + effColor + ';">' + s.adoption + ' DOTs use this</span>' +
      '</div>' +
      '<div style="font-size:13px;font-weight:700;color:var(--ink);margin-bottom:4px;">' + s.title + '</div>' +
      '<div style="font-size:12px;color:var(--ink2);line-height:1.65;">' + s.desc + '</div>' +
      '</div>';
  });
  document.getElementById('org-strategies').innerHTML = orgHtml;
}

