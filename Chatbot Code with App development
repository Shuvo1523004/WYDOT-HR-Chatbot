async function sendChat() {
  const input = document.getElementById('chat-input');
  const msg = input.value.trim();
  if (!msg) return;

  const hasKey = (activeProvider === 'google' && googleApiKey) ||
                 (activeProvider === 'anthropic' && anthropicApiKey);
  if (!hasKey) {
    alert('Please add an API key in the AI Assistant setup panel.\n\nOption 1 (Free): Google AI Studio key from aistudio.google.com\nOption 2: Anthropic key from console.anthropic.com');
    return;
  }

  input.value = '';
  appendMessage('user', msg);
  chatHistory.push({ role: 'user', content: msg });
  const typingDiv = appendMessage('ai', '⋯ thinking');
  typingDiv.id = 'typing-msg';

  try {
    let reply = '';

    if (activeProvider === 'google' && googleApiKey) {
      const geminiContents = [];
      for (let i = 0; i < chatHistory.length - 1; i++) {
        geminiContents.push({
          role: chatHistory[i].role === 'assistant' ? 'model' : 'user',
          parts: [{ text: chatHistory[i].content }]
        });
      }
      geminiContents.push({ role: 'user', parts: [{ text: msg }] });

      const res = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${googleApiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            system_instruction: { parts: [{ text: WYDOT_SYSTEM_PROMPT }] },
            contents: geminiContents,
            generationConfig: { maxOutputTokens: 1000, temperature: 0.7 }
          })
        }
      );
      const data = await res.json();
      if (data.error) throw new Error(data.error.message || JSON.stringify(data.error));
      reply = data.candidates?.[0]?.content?.parts?.[0]?.text || 'No response from Gemini.';

    } else {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: WYDOT_SYSTEM_PROMPT,
          messages: chatHistory
        })
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error.message || JSON.stringify(data.error));
      reply = data.content?.[0]?.text || 'No response from Claude.';
    }

    document.getElementById('typing-msg')?.remove();
    appendMessage('ai', reply);
    chatHistory.push({ role: 'assistant', content: reply });
    if (chatHistory.length > 20) chatHistory = chatHistory.slice(-18);

  } catch (err) {
    document.getElementById('typing-msg')?.remove();
    appendMessage('ai', `Error: ${err.message}. Please check your API key and try again.`);
  }
}

function appendMessage(role, text) {
  const msgs = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'msg ' + role;
  div.innerHTML = `
    <div class="msg-avatar">${role==='ai'?'W':'HR'}</div>
    <div class="msg-bubble">${text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/•/g,'•')}</div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  return div;
}

function sendQuick(msg) {
  document.getElementById('chat-input').value = msg;
  sendChat();
}

