/* ─── BATCH FILE UPLOAD ─── */
function handleFileUpload(input) {
  const file = input.files[0];
  if (!file) return;
  showOverlay('Reading and validating file...');

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const wb = XLSX.read(e.target.result, { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const raw = XLSX.utils.sheet_to_json(ws, { defval: null });
      processBatchData(raw);
    } catch(err) {
      hideOverlay();
      alert('Error reading file: ' + err.message);
    }
  };
  reader.readAsArrayBuffer(file);
}

function processBatchData(rows) {
  showOverlay('Running turnover risk predictions...');
  setTimeout(() => {
    const results = rows.map((row, idx) => {
      // Try to map columns to our field names (fuzzy matching)
      const data = mapRowToFields(row);
      const { risk } = computeRisk(data);
      const themeScores = computeThemeScores(data);
      const { cat, cls } = getRiskCat(risk);
      const worstTheme = Object.entries(themeScores).sort((a,b) => a[1]-b[1])[0]; // lowest score = worst theme (1=Poor)
      return {
        idx: idx + 1,
        id: row['EmployeeID'] || row['Employee_ID'] || row['Name'] || ('EMP-' + String(idx+1).padStart(3,'0')),
        risk: Math.round(risk * 100),
        cat, cls,
        worstTheme: worstTheme[0],
        themeScores,
        data
      };
    });

    renderBatchResults(results);
    hideOverlay();
  }, 800);
}

